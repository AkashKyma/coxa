# ══════════════════════════════════════════════════════════════════════════════
# fanbox-dashboard — Production Environment Variables
# Copy this file to .env.local and fill in real values before deploying.
# ══════════════════════════════════════════════════════════════════════════════

# ── API Backend ───────────────────────────────────────────────────────────────
# URL of the Coxa backend (ELB or API gateway). No trailing slash.
# If the frontend is served from the same origin as the backend, leave empty.
VITE_API_URL=https://api.coxa.live

# ── RudderStack (client-side event tracking) ──────────────────────────────────
# Get the JS/Web write key from your self-hosted RudderStack source settings.
VITE_RUDDERSTACK_WRITE_KEY=rws_2cb392007d9b69839f418856bfa09a7d2e296419
VITE_RUDDERSTACK_DATA_PLANE_URL=http://3.217.225.85:8080

# ── PostHog (product analytics + session replay) ──────────────────────────────
# Get the project API key from PostHog → Settings → Project.
VITE_POSTHOG_KEY=phc_A4Gnk9ev6nQJ8TfXoAq48DusKakeCBpgJNagZbp9ek3b
VITE_POSTHOG_HOST=https://posthog.service.coxa.live

# ── Tracardi (visual segment builder GUI) ─────────────────────────────────────
# Public HTTPS URL to the Tracardi GUI. Used for "Open in Tracardi" links and iframe embedding.
VITE_TRACARDI_GUI_URL=https://tracardi.service.coxa.live

# ── Fan Dashboard — Vite Environment Variables ───────────────────────────────
# Copy to .env for local development.
# In production these are injected by the Amplify build (amplify.yml) from
# the values set in Amplify Console → App settings → Environment variables.

# Base URL of the backend API (no trailing slash)
VITE_API_URL=http://localhost:5000

# URL of the fan auth app — unauthenticated users are redirected here
VITE_AUTH_URL=http://localhost:5175

# Tenant identifier sent as x-tenant-id header on every API request
VITE_TENANT_ID=coxa-club-001

# ── Production values (set in Amplify Console, NOT in this file) ─────────────
# VITE_API_URL=https://api.coxa.live
# VITE_AUTH_URL=https://id.coxa.live
# VITE_TENANT_ID=coxa-club-001

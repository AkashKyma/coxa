<clickhouse>
    <!-- Define shard and replica macros for ReplicatedMergeTree tables -->
    <macros>
        <shard>1</shard>
        <replica>1</replica>
        <hostClusterType>hobby</hostClusterType>
        <hostClusterRole>replica</hostClusterRole>
    </macros>

    <!-- Define Keeper Server -->
    <keeper_server>
        <tcp_port>9181</tcp_port>
        <storage_path>/var/lib/clickhouse/coordination/</storage_path>
        <server_id>1</server_id>
        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>127.0.0.1</hostname>
                <port>9234</port>
            </server>
        </raft_configuration>
    </keeper_server>

    <!-- Tell ClickHouse to use the Keeper Server as ZooKeeper -->
    <zookeeper>
        <node index="1">
            <host>127.0.0.1</host>
            <port>9181</port>
        </node>
    </zookeeper>

    <!-- Define ClickHouse Named Collections -->
    <named_collections>
        <msk_cluster>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </msk_cluster>
        <warpstream_ingestion>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </warpstream_ingestion>
        <warpstream_calculated_events>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </warpstream_calculated_events>
        <warpstream_cyclotron>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </warpstream_cyclotron>
        <warpstream_kafka_producer>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </warpstream_kafka_producer>
        <warpstream_logs>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </warpstream_logs>
        <warpstream_metrics>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </warpstream_metrics>
        <warpstream_replay>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </warpstream_replay>
        <warpstream_shared>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </warpstream_shared>
        <warpstream_shared_kafka_engines>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </warpstream_shared_kafka_engines>
        <warpstream_traces>
            <kafka_broker_list>kafka:9092</kafka_broker_list>
        </warpstream_traces>
    </named_collections>

    <!-- PostHog migrations create metrics over system.crash_log. -->
    <crash_log>
        <database>system</database>
        <table>crash_log</table>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
        <max_size_rows>1024</max_size_rows>
        <reserved_size_rows>1024</reserved_size_rows>
        <buffer_size_rows_flush_threshold>512</buffer_size_rows_flush_threshold>
        <flush_on_crash>false</flush_on_crash>
    </crash_log>

    <!-- Define remote servers / clusters -->
    <remote_servers>
        <posthog_migrations>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </posthog_migrations>
        <posthog>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </posthog>
        <posthog_primary_replica>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </posthog_primary_replica>
        <posthog_single_shard>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </posthog_single_shard>
        <posthog_writable>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </posthog_writable>
        <ai_events>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </ai_events>
        <web_analytics>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </web_analytics>
        <aux>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </aux>
        <batch_exports>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </batch_exports>
        <ops>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </ops>
        <sessions>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </sessions>
        <session_replay>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </session_replay>
        <logs>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </logs>
        <cdp>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </cdp>
        <data_warehouse>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </data_warehouse>
        <customer_analytics>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </customer_analytics>
        <default>
            <shard>
                <replica>
                    <host>posthog-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </default>
    </remote_servers>
</clickhouse>

# ══════════════════════════════════════════════════════════════════════════════
# CDP Infrastructure — EC2 Environment (.env.cdp)
# EC2 Elastic IP: 3.217.225.85  |  Region: us-east-1
#
# ⚠️  BEFORE GOING LIVE:
#   - Replace ALL <CHANGE_ME_...> values with real secrets
#   - Generate passwords with: openssl rand -hex 24
#   - Generate salts/secrets with: openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════════════════

# ── Phase 1: RudderStack ──────────────────────────────────────────────────────
RUDDERSTACK_DATA_PLANE_URL=http://3.217.225.85:8080
RUDDERSTACK_BACKEND_WRITE_KEY=rbs_36b0b76d1de95af77a05ca30fc46328cf70b07af
RUDDERSTACK_WEB_WRITE_KEY=rws_2cb392007d9b69839f418856bfa09a7d2e296419
# Get workspace token from your RudderStack control-plane workspace settings
RUDDERSTACK_WORKSPACE_TOKEN=<CHANGE_ME_RUDDERSTACK_WORKSPACE_TOKEN>
# Must match the signing secret configured in your RudderStack webhook source
RUDDERSTACK_WEBHOOK_SECRET=<CHANGE_ME_RUDDERSTACK_WEBHOOK_SECRET>
# Generate: openssl rand -hex 24
RUDDERSTACK_DB_PASSWORD=<CHANGE_ME_RUDDERSTACK_DB_PASSWORD>

# ── Phase 1: PostHog ──────────────────────────────────────────────────────────
POSTHOG_HOST=https://posthog.service.coxa.live
POSTHOG_PROJECT_API_KEY=phc_A4Gnk9ev6nQJ8TfXoAq48DusKakeCBpgJNagZbp9ek3b
# Generate: openssl rand -hex 32
POSTHOG_SECRET_KEY=<CHANGE_ME_POSTHOG_SECRET_KEY>
POSTHOG_SITE_URL=https://posthog.service.coxa.live
# Generate: openssl rand -hex 24
POSTHOG_DB_PASSWORD=<CHANGE_ME_POSTHOG_DB_PASSWORD>
# Generate: openssl rand -hex 16  (exactly 32 hex chars)
POSTHOG_ENCRYPTION_SALT_KEYS=<CHANGE_ME_32HEX_SALT>
# Tighten to actual domain in production (currently * is fine with Caddy proxy)
POSTHOG_ALLOWED_HOSTS=posthog.service.coxa.live

# ── Phase 2: ClickHouse ────────────────────────────────────────────────────────
# ClickHouse is internal-only (port blocked at Security Group level).
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=coxa
CLICKHOUSE_USER=coxa
# Generate: openssl rand -hex 24
CLICKHOUSE_PASSWORD=<CHANGE_ME_CLICKHOUSE_PASSWORD>

# ── Phase 2: Cube Semantic Layer ──────────────────────────────────────────────
# Cube API is exposed on port 4000 (open to ELB SG only).
CUBE_API_URL=http://3.217.225.85:4000/cubejs-api/v1
# Generate: openssl rand -hex 32  — must match CUBE_API_SECRET in backend .env
CUBE_API_SECRET=<CHANGE_ME_CUBE_API_SECRET>
# Set to false in production to disable Cube Playground UI
CUBEJS_DEV_MODE=false
# Set to redis for persistence across restarts
CUBEJS_CACHE_DRIVER=memory

# ── Phase 2: Dagster ──────────────────────────────────────────────────────────
# Generate: openssl rand -hex 24
DAGSTER_DB_PASSWORD=<CHANGE_ME_DAGSTER_DB_PASSWORD>

# ── Phase 3: Tracardi ─────────────────────────────────────────────────────────
# HTTPS domains (via Caddy) — set after DNS records are created:
#   tracardi.service.coxa.live      → GUI  (visual segment builder)
#   tracardi-api.service.coxa.live  → API  (backend + webhook bridge)
TRACARDI_HOST=https://tracardi-api.service.coxa.live
TRACARDI_SOURCE_ID=coxa-rudderstack
TRACARDI_LICENSE_KEY=
# Admin credentials — set on first login in the Tracardi UI
TRACARDI_USERNAME=admin
TRACARDI_PASSWORD=<CHANGE_ME_TRACARDI_PASSWORD>

# ── Phase 4: Multiwoven (Reverse ETL) ─────────────────────────────────────────
# UI: http://3.217.225.85:8095
# Generate: openssl rand -hex 24
MULTIWOVEN_DB_PASSWORD=<CHANGE_ME_MULTIWOVEN_DB_PASSWORD>
# Generate: openssl rand -hex 64
MULTIWOVEN_SECRET_KEY_BASE=<CHANGE_ME_MULTIWOVEN_SECRET_KEY_BASE>

# ══════════════════════════════════════════════════════════════════════════════
# COXA BACKEND — ELB Production Environment
# Last updated: 2026-07-13
# EC2 Elastic IP: 3.217.225.85 (STATIC — Elastic IP assigned)
#
# ⚠️  BEFORE DEPLOYING TO PRODUCTION:
#   1. Replace ALL <CHANGE_ME_...> placeholders with real secrets
#   2. Update MONGODB_URI to point to the production Atlas cluster (not staging)
#   3. Update CORS URLs (CLUB_AUTH_URL etc.) to real production domains
#   4. Rotate OPENAI_API_KEY — generate a fresh key from platform.openai.com
# ══════════════════════════════════════════════════════════════════════════════

# ── MongoDB ───────────────────────────────────────────────────────────────────
# ⚠️  Update the database name from "coxa-staging" to your production cluster
MONGODB_URI=mongodb+srv://abhishek_db_user:RxTWEK56hLHDzLpL@cms.imbxra8.mongodb.net/coxa-production

# ── Express Backend ───────────────────────────────────────────────────────────
API_PORT=5000
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<CHANGE_ME_JWT_SECRET_MIN_64_CHARS>
JWT_EXPIRES_IN=7d

# ── CORS — Frontend origins ───────────────────────────────────────────────────
# Set to the actual production domain of each frontend app.
CLUB_AUTH_URL=https://auth.coxa.live
CLUB_DASHBOARD_URL=https://club.coxa.live
FAN_AUTH_URL=https://id.coxa.live
FAN_DASHBOARD_URL=https://fan.coxa.live
FANBOX_DASHBOARD_URL=https://fanbox.coxa.live
POS_APP_URL=https://pos.coxa.live

# ── Tenant ────────────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=coxa-club-001

# ── Medusa 2.x (retail / F&B / marketplace) ──────────────────────────────────
MEDUSA_URL=http://localhost:9000
DATABASE_URL=postgres://postgres:<CHANGE_ME_MEDUSA_DB_PASSWORD>@localhost:5432/coxa_medusa
REDIS_URL=redis://localhost:6379

# ── AI / OpenAI ───────────────────────────────────────────────────────────────
# ⚠️  Generate a new key at platform.openai.com — do NOT commit real keys to git
OPENAI_API_KEY=<CHANGE_ME_OPENAI_API_KEY>
AI_MODEL=gpt-4o
AI_EMBED_MODEL=text-embedding-3-large
AI_EMBED_DIMS=3072

# ══════════════════════════════════════════════════════════════════════════════
# CDP — Phase 1  (RudderStack + PostHog on EC2)
# EC2 instance: i-09ec7300ad9e03274  region: us-east-1
# ══════════════════════════════════════════════════════════════════════════════

# ── RudderStack (event streaming) ────────────────────────────────────────────
RUDDERSTACK_DATA_PLANE_URL=http://3.217.225.85:8080
RUDDERSTACK_BACKEND_WRITE_KEY=rbs_36b0b76d1de95af77a05ca30fc46328cf70b07af
# Web write key (used by frontend apps):  rws_2cb392007d9b69839f418856bfa09a7d2e296419
# ⚠️  Get the real webhook signing secret from RudderStack source settings
RUDDERSTACK_WEBHOOK_SECRET=<CHANGE_ME_RUDDERSTACK_WEBHOOK_SECRET>

# ── PostHog (product analytics + feature flags) ───────────────────────────────
POSTHOG_HOST=https://posthog.service.coxa.live
# Get this key from: PostHog UI → Settings → Project API Key (starts with phc_)
POSTHOG_PROJECT_API_KEY=phc_A4Gnk9ev6nQJ8TfXoAq48DusKakeCBpgJNagZbp9ek3b

# ── Phase 2: Cube (backend on ELB → Cube on EC2 via public IP) ───────────────
# Port 4000 is open on the EC2 Security Group for ELB access.
# ClickHouse and Dagster remain internal — only Cube is needed from ELB.
CUBE_API_URL=http://3.217.225.85:4000/cubejs-api/v1
# ⚠️  Must match CUBEJS_API_SECRET in docker-compose.cdp.yml on EC2
CUBE_API_SECRET=<CHANGE_ME_CUBE_API_SECRET>

# ── Phase 3: ClickHouse (accessed via localhost on EC2 — NOT exposed publicly) ──
# These are only needed if the backend itself runs on the EC2 (not on ELB).
# For ELB deployments, ClickHouse is accessed via Cube only (see CUBE_API_URL above).
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=coxa
CLICKHOUSE_USER=coxa
CLICKHOUSE_PASSWORD=<CHANGE_ME_CLICKHOUSE_PASSWORD>

# ── Phase 3: Tracardi (visual segment builder + CDP profiles on EC2) ──────────
# The backend calls Tracardi's REST API to proxy segment data to the dashboards.
TRACARDI_HOST=https://tracardi-api.service.coxa.live
TRACARDI_USERNAME=admin@coxa.live
TRACARDI_PASSWORD=admin

# ══════════════════════════════════════════════════════════════════════════════
# EMAIL — Phase 2 Campaign Delivery
# Set EMAIL_ENABLED=true and fill SMTP_* to enable transactional/campaign emails.
# Recommended provider: Brevo (smtp-relay.brevo.com:587) — free tier: 300/day
# ══════════════════════════════════════════════════════════════════════════════
EMAIL_ENABLED=false
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<CHANGE_ME_BREVO_LOGIN_EMAIL>
SMTP_PASS=<CHANGE_ME_BREVO_SMTP_API_KEY>
SMTP_FROM=Coxa Club <noreply@coxa.live>

# ══════════════════════════════════════════════════════════════════════════════
# WEB PUSH — Phase 2  (VAPID keys for browser push notifications)
# Generate keys: node -e "const wl=require('web-push'); console.log(JSON.stringify(wl.generateVAPIDKeys(),null,2))"
# ══════════════════════════════════════════════════════════════════════════════
VAPID_PUBLIC_KEY=<CHANGE_ME_VAPID_PUBLIC_KEY>
VAPID_PRIVATE_KEY=<CHANGE_ME_VAPID_PRIVATE_KEY>
VAPID_EMAIL=mailto:noreply@coxa.live
# Optional: Firebase Admin SDK JSON (base64-encoded) for FCM mobile push
# FIREBASE_SERVICE_ACCOUNT_JSON=<base64 encoded service account JSON>

# ══════════════════════════════════════════════════════════════════════════════
# MULTIWOVEN — Reverse ETL (sync segments to external CRMs/ad platforms)
# Self-hosted on EC2, accessible via internal Docker network or public IP.
# ══════════════════════════════════════════════════════════════════════════════
MULTIWOVEN_HOST=http://3.217.225.85:3050
MULTIWOVEN_API_KEY=<CHANGE_ME_MULTIWOVEN_API_KEY>

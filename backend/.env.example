# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local dev:
MONGODB_URI=mongodb://localhost:27017/coxa
# Atlas production example:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/coxa?retryWrites=true
# Optional read-only connection string for CDP analytics (defaults to MONGODB_URI):
# MONGODB_READ_URI=mongodb+srv://analytics-ro:pass@cluster.mongodb.net/coxa?readPreference=secondary
# Mongoose connection pool, PER CLUSTER WORKER.
# Effective pool = WEB_CONCURRENCY × instance_count × MONGO_POOL_SIZE.
# Default 25 keeps a fleet of 8 workers × 10 instances inside Atlas M30 (3k cap).
# Set higher only for low-concurrency / single-instance deploys.
MONGO_POOL_SIZE=25

# ── Server ────────────────────────────────────────────────────────────────────
# EB sets PORT automatically (8080 on AL2023 nginx platform). 5000 is dev-only.
PORT=5000
NODE_ENV=development
# Cluster worker count. Leave unset in production to use one worker per CPU
# (capped at 16). Set to 1 for local dev so nodemon restarts are clean.
WEB_CONCURRENCY=1

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be changed before production — use a long random string
JWT_SECRET=coxa_dev_secret_change_in_production
JWT_EXPIRES_IN=7d
# Auth cache TTL in seconds (how long user+membership is cached in Redis)
AUTH_CACHE_TTL=90

# ── Tenant ────────────────────────────────────────────────────────────────────
# Default tenant when x-tenant-id header is absent
DEFAULT_TENANT_ID=coxa-club-001

# ── CORS — Allowed frontend origins ──────────────────────────────────────────
CLUB_AUTH_URL=http://localhost:5173
CLUB_DASHBOARD_URL=http://localhost:5174
FAN_AUTH_URL=http://localhost:5175
FAN_DASHBOARD_URL=http://localhost:5176
FANBOX_DASHBOARD_URL=http://localhost:5178
POS_APP_URL=http://localhost:5177

# ── Redis (ElastiCache in production) ────────────────────────────────────────
# Leave empty to run without Redis (auth cache and queues disabled)
REDIS_URL=
# Production: AWS ElastiCache Serverless is TLS-only — use rediss:// (two s's).
# REDIS_URL=rediss://coxa-redis-cache-XXXX.serverless.use1.cache.amazonaws.com:6379
# Self-managed plaintext example:
# REDIS_URL=redis://your-elasticache-endpoint.cache.amazonaws.com:6379

# ── OpenAI — required for AI Insights, RAG chatbot, KPI summaries ────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Generation model (default: gpt-4o-mini).  Use gpt-4o for higher quality.
AI_MODEL=gpt-4o
# Embedding model + dimensions — must match what was used to seed the knowledge base.
# Changing these after seeding requires a full re-seed of the RAG collection.
AI_EMBED_MODEL=text-embedding-3-large
AI_EMBED_DIMS=3072

# ── Social Ingestion (leave empty to skip automatic ingestion) ────────────────
# Instagram Graph API — long-lived page access token
INSTAGRAM_ACCESS_TOKEN=
# Twitter/X API v2 — Bearer token (read-only app token is sufficient)
TWITTER_BEARER_TOKEN=
# YouTube Data API v3 key
YOUTUBE_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── MCP Server (auto-started with the backend) ────────────────────────────────
# Set MCP_ENABLED=false to disable the MCP sidecar
MCP_ENABLED=true
# Base URL the MCP tools call to reach the REST API (defaults to same port)
MCP_API_URL=http://localhost:5000
MCP_TENANT_ID=coxa-club-001
# Transport: stdio (Cursor/Claude Desktop) or http (remote agents / production)
# Defaults to stdio in dev, http in production
MCP_TRANSPORT=stdio
MCP_PORT=3100

# ── CDP Infrastructure (RudderStack + PostHog) ────────────────────────────────
RUDDERSTACK_DATA_PLANE_URL=http://localhost:8080
RUDDERSTACK_BACKEND_WRITE_KEY=COXA_BACKEND_WRITE_KEY_CHANGE_ME
RUDDERSTACK_WEBHOOK_SECRET=COXA_RUDDERSTACK_WEBHOOK_SECRET_CHANGE_ME
POSTHOG_HOST=http://localhost:8000
POSTHOG_PROJECT_API_KEY=phc_your_posthog_project_api_key

# ── Phase 2: Cube Semantic Layer + ClickHouse ─────────────────────────────────
CUBE_API_URL=http://localhost:4000/cubejs-api/v1
CUBE_API_SECRET=coxa-cube-dev-secret-change-in-prod
CLICKHOUSE_HOST=localhost
CLICKHOUSE_USER=coxa
CLICKHOUSE_PASSWORD=coxa_dev_password

# ── Worker concurrency (only used when running npm run start:worker) ──────────
WORKER_CONCURRENCY=10

# ── Production examples (Elastic Beanstalk environment variables) ─────────────
# NODE_OPTIONS=--max-old-space-size=6144
# CLUB_AUTH_URL=https://club-auth.yourclub.com
# CLUB_DASHBOARD_URL=https://club.yourclub.com
# FAN_AUTH_URL=https://fan-auth.yourclub.com
# FAN_DASHBOARD_URL=https://fan.yourclub.com
# FANBOX_DASHBOARD_URL=https://fanbox.yourclub.com
# POS_APP_URL=https://pos.yourclub.com

# MongoDB (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/coxa

# Backend API
API_PORT=5000
NODE_ENV=development

# JWT — MUST change before production
JWT_SECRET=coxa_dev_secret_change_in_production
JWT_EXPIRES_IN=7d

# Allowed frontend origins (for CORS) — use HTTPS URLs in production
CLUB_AUTH_URL=http://localhost:5173
CLUB_DASHBOARD_URL=http://localhost:5174
FAN_AUTH_URL=http://localhost:5175
FAN_DASHBOARD_URL=http://localhost:5176
POS_APP_URL=http://localhost:5177

# Tenant (single-club MVP)
DEFAULT_TENANT_ID=coxa-club-001

# ── AWS / EC2 ops scripts (scripts/*.mjs, scripts/*.py) ───────────────────────
# NEVER commit real keys. Copy this file to `.env` and fill values locally.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

EC2_INSTANCE_ID=
EC2_PUBLIC_IP=
EC2_ELASTIC_IP=
EC2_SSH_USER=ubuntu
EC2_WORK_DIR=/home/ubuntu/coxa-1touch
EC2_AZ=us-east-1b
EC2_TARGET_TYPE=t3.large
EIC_ENDPOINT_ID=
EBS_VOLUME_ID=
EBS_NEW_SIZE_GB=60

ROUTE53_ZONE_ID=
POSTHOG_DOMAIN=posthog.service.coxa.live
TRACARDI_DOMAIN=tracardi.service.coxa.live
TRACARDI_API_DOMAIN=tracardi-api.service.coxa.live

EC2_IP_POSTHOG_SETUP=
EC2_IP_CUBE=

# OpenAI (also used by backend — prefer backend/.env for app runtime)
OPENAI_API_KEY=

# ── CDP (RudderStack / PostHog) ──────────────────────────────────────────────
RUDDERSTACK_DATA_PLANE_URL=http://localhost:8080
RUDDERSTACK_BACKEND_WRITE_KEY=
RUDDERSTACK_WEB_WRITE_KEY=
RUDDERSTACK_WORKSPACE_TOKEN=
RUDDERSTACK_WEBHOOK_SECRET=
RUDDERSTACK_DB_PASSWORD=
POSTHOG_HOST=http://localhost:8000
POSTHOG_PROJECT_API_KEY=
POSTHOG_SECRET_KEY=
POSTHOG_ENCRYPTION_SALT_KEYS=
POSTHOG_SITE_URL=http://localhost:8000
POSTHOG_DB_PASSWORD=

# ── Production examples (Amplify + Elastic Beanstalk) ───────────────────────
# API_URL=https://api.yourdomain.com
# CLUB_AUTH_URL=https://club-auth.yourdomain.com
# CLUB_DASHBOARD_URL=https://club.yourdomain.com
# FAN_AUTH_URL=https://fan-auth.yourdomain.com
# FAN_DASHBOARD_URL=https://fan.yourdomain.com
# POS_APP_URL=https://pos.yourdomain.com
#
# Frontend build-time (set in Amplify per app):
# VITE_API_URL=https://api.yourdomain.com
# VITE_AUTH_URL=...
# VITE_DASHBOARD_URL=...
# VITE_TENANT_ID=coxa-club-001

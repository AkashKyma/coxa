option_settings:
  # ── App-level environment ─────────────────────────────────────────────
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    # Leave WEB_CONCURRENCY unset so cluster.js picks one worker per CPU.
    # Bump Node heap to fit big match-day payloads (default 4GB on t3.xlarge).
    NODE_OPTIONS: "--max-old-space-size=6144"

  # ── Health checks (nginx → node) ──────────────────────────────────────
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /api/health
    MatcherHTTPCode: "200"
    HealthCheckInterval: "15"
    HealthyThresholdCount: "2"
    UnhealthyThresholdCount: "3"
    # Keep idle backend connections warm — must match node's keepAliveTimeout.
    StickinessEnabled: "false"

  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced

  # ── ALB idle timeout ──────────────────────────────────────────────────
  # Default 60s drops SSE/long polls. Bumped to 120s to outlive nginx (75s)
  # and node (75s) keepalive so we don't see "upstream prematurely closed"
  # storms under load.
  aws:elbv2:loadbalancer:
    IdleTimeout: "120"

  # ── Auto Scaling ──────────────────────────────────────────────────────
  # Match-day target: 100k concurrent users. Sized for ~5k–15k RPS.
  # Tune instance type + capacity to your real per-instance throughput
  # (load test with k6/artillery before locking these numbers in).
  aws:autoscaling:asg:
    MinSize: "2"
    MaxSize: "20"
    Cooldown: "180"

  aws:autoscaling:launchconfiguration:
    InstanceType: t3.xlarge
    RootVolumeType: gp3
    RootVolumeSize: "20"

  # Scale on CPU — pragmatic proxy for "node event loop is saturated".
  # Add a request-count policy via the console if you need finer control.
  aws:autoscaling:trigger:
    MeasureName: CPUUtilization
    Statistic: Average
    Unit: Percent
    Period: "1"
    BreachDuration: "2"
    UpperThreshold: "65"
    UpperBreachScaleIncrement: "2"
    LowerThreshold: "25"
    LowerBreachScaleIncrement: "-1"

  # Rolling deploys so we don't drop the whole fleet at once on match day.
  aws:elasticbeanstalk:command:
    DeploymentPolicy: RollingWithAdditionalBatch
    BatchSizeType: Percentage
    BatchSize: "50"
    HealthCheckSuccessThreshold: Ok
    Timeout: "600"

# ── Nginx tuning ────────────────────────────────────────────────────────
# Bumps worker_connections and keepalive so a single instance can hold
# the long tail of idle ALB / browser sockets without ECONNRESET.
files:
  "/etc/nginx/conf.d/coxa-upstream-tuning.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Coxa: keep upstream sockets warm. keepalive_timeout MUST be lower
      # than node's server.keepAliveTimeout (75s) so node, not nginx, is
      # the one that ever closes a reused socket — eliminates the race that
      # produces "upstream prematurely closed" 502s under heavy load.
      keepalive_timeout 65s;
      keepalive_requests 1000;
      client_max_body_size 25m;

  "/etc/nginx/conf.d/elasticbeanstalk/00_application.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Override EB's default upstream block to add a connection pool to node.
      upstream nodejs {
        server 127.0.0.1:8080 max_fails=3 fail_timeout=5s;
        keepalive 64;
      }

      location / {
        proxy_pass            http://nodejs;
        proxy_http_version    1.1;
        proxy_set_header      Connection          "";
        proxy_set_header      Host                $host;
        proxy_set_header      X-Real-IP           $remote_addr;
        proxy_set_header      X-Forwarded-For     $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto   $scheme;
        proxy_read_timeout    65s;
        proxy_send_timeout    65s;
      }
